      "bEnabled": true,
      "bPlotOnly": false,
      "bInteractive": false,
      "saDataCommands": [
        "echo --- EngleBarnes: copying priors ---",
        "cp {Step01.flare_mcmc_samples} EngleBarnes/flares_variable_slope.npy",
        "cp {Step07.age_samples} EngleBarnes/age_samples.txt",
        "cp {Step09.dynesty_transform_final} EngleBarnes/dynesty_transform_final.npy",
        "cp EngleBarnes/output/Converged_Param_Dictionary.json EngleBarnes/.Converged_Param_Dictionary.json.bak 2>/dev/null; true",
