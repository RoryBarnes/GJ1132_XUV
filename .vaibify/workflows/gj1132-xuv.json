        "cd EngleBarnes && vconverge vconverge.in || (cp .Converged_Param_Dictionary.json.bak output/Converged_Param_Dictionary.json 2>/dev/null; exit 1)",
        "rm -f EngleBarnes/.Converged_Param_Dictionary.json.bak",
        "echo --- RibasBarnes: copying priors ---",
        "cp {Step01.flare_mcmc_samples} RibasBarnes/flares_variable_slope.npy",
